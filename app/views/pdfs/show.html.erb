<h1>Texto OCR bruto</h1>

<pre>
  <!-- 
    Aqui mostra o texto OCR cru que veio do PDF.
    Use <%=h ... %> ou <%= ... %> pra escapar HTML perigoso.
  -->
  <%= @pdf.ocr_text %>
</pre>

<h2>Alunos extraídos</h2>

<table>
  <thead>
    <tr>
      <th>Matrícula</th>
      <th>Nome</th>
    </tr>
  </thead>
  <tbody>
    <% @alunos.each do |aluno| %>
      <tr>
        <td><%= aluno[:matricula] %></td>
        <td><%= aluno[:nome] %></td>
      </tr>
    <% end %>
  </tbody>
</table>
